# ============================================================
#  AlertAU — Environment Variables
#  Copy this file, rename to .env, and fill in your keys.
#  NEVER commit .env to GitHub.
# ============================================================

# NASA FIRMS — Free fire hotspot data
# Sign up at: https://firms.modaps.eosdis.nasa.gov/api/
NASA_FIRMS_KEY=YOUR_NASA_FIRMS_KEY_HERE

# OpenWeatherMap — Free weather alerts (One Call API 3.0)
# Sign up at: https://openweathermap.org/api
OPENWEATHER_KEY=YOUR_OPENWEATHER_KEY_HERE

# OpenAI — GPT-4o-mini for AI safety summaries
# Sign up at: https://platform.openai.com/api-keys
OPENAI_KEY=YOUR_OPENAI_KEY_HERE

# Your backend server URL (set after you deploy the backend)
# For local dev use: http://localhost:3001
API_BASE_URL=http://localhost:3001
